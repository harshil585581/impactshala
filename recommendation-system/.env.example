# ─── Supabase ─────────────────────────────────────────────────────────────────
# Find these in: Supabase Dashboard → Project Settings → Database
SUPABASE_URL=https://<project-ref>.supabase.co
SUPABASE_ANON_KEY=<your-anon-key>
SUPABASE_SERVICE_ROLE_KEY=<your-service-role-key>

# Direct connection (for Alembic migrations & heavy queries)
# Dashboard → Settings → Database → Connection string → URI
DATABASE_URL=postgresql+asyncpg://postgres:<password>@db.<project-ref>.supabase.co:5432/postgres

# Sync URL for Alembic (psycopg2)
SYNC_DATABASE_URL=postgresql+psycopg2://postgres:<password>@db.<project-ref>.supabase.co:5432/postgres

# Supabase connection pooler — use this for the app (Supavisor, port 6543)
# Dashboard → Settings → Database → Connection pooling → URI
DATABASE_POOL_URL=postgresql+asyncpg://postgres.<project-ref>:<password>@aws-0-<region>.pooler.supabase.com:6543/postgres

# ─── Redis (local or Upstash / Redis Cloud) ───────────────────────────────────
REDIS_URL=redis://localhost:6379/0

# ─── Celery ───────────────────────────────────────────────────────────────────
CELERY_BROKER_URL=redis://localhost:6379/1
CELERY_RESULT_BACKEND=redis://localhost:6379/2

# ─── App ──────────────────────────────────────────────────────────────────────
APP_ENV=development
SECRET_KEY=change-me-in-production-32chars-min
LOG_LEVEL=INFO

# ─── ML ───────────────────────────────────────────────────────────────────────
FAISS_INDEX_PATH=data/content_embeddings.index
EMBEDDING_MODEL=all-MiniLM-L6-v2
RANKING_MODEL_PATH=data/ranking_model.pkl
